{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "creeper-notes",
  "version": "0.1.0",
  "identifier": "com.creeper.creeper-notes",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "creeper-notes",
        "width": 450,
        "height": 550,
        "minWidth": 450,
        "minHeight": 550,
        "decorations": false,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.icns", "icons/icon.ico"]
  }
}
